{
	"compatibility_date": "2026-04-06",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "weston-pub",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
