---
interface Props {
  title: string;
}
const { title } = Astro.props;
const pageTitle = `${title} — weston.pub`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --surface: #141414;
        --border: #2a2a2a;
        --text: #e8e8e8;
        --muted: #9a9a9a;
        --accent: #7eb8da;
        --accent-dim: #5a9aba;
        --notice: #c9a227;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
      }
      .wrap {
        max-width: 40rem;
        margin: 0 auto;
        padding: 2.5rem 1.25rem 4rem;
      }
      nav.back {
        margin-bottom: 1.5rem;
      }
      nav.back a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
      }
      nav.back a:hover {
        color: var(--accent);
      }
      article h1 {
        margin: 0 0 1rem;
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: -0.02em;
      }
      .notice {
        background: var(--surface);
        border: 1px solid var(--border);
        border-left: 3px solid var(--notice);
        border-radius: 8px;
        padding: 0.85rem 1rem;
        margin-bottom: 1.25rem;
        font-size: 0.9rem;
        color: var(--text);
      }
      .notice strong {
        color: var(--notice);
      }
      article p.summary {
        margin: 0 0 1.25rem;
        color: var(--muted);
        font-size: 0.95rem;
      }
      a.gh {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.85rem;
        font-size: 0.85rem;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--bg);
        color: var(--accent);
        text-decoration: none;
      }
      a.gh:hover {
        border-color: var(--accent-dim);
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <nav class="back" aria-label="Site">
        <a href="/">← weston.pub</a>
      </nav>
      <article>
        <slot />
      </article>
    </div>
  </body>
</html>
