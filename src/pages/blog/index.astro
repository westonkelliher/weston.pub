---
export const prerender = true;
import { posts } from '../../data/posts';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>blog — weston.pub</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --surface: #141414;
        --border: #2a2a2a;
        --text: #e8e8e8;
        --muted: #9a9a9a;
        --accent: #7eb8da;
        --accent-dim: #5a9aba;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
      }
      .wrap {
        max-width: 40rem;
        margin: 0 auto;
        padding: 2.5rem 1.25rem 4rem;
      }
      nav.back {
        margin-bottom: 1.5rem;
      }
      nav.back a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
      }
      nav.back a:hover {
        color: var(--accent);
      }
      h1 {
        margin: 0 0 1.5rem;
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: -0.02em;
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-list li {
        border-bottom: 1px solid var(--border);
        padding: 1rem 0;
      }
      .post-list li:first-child {
        border-top: 1px solid var(--border);
      }
      .post-list a {
        text-decoration: none;
        color: var(--text);
        display: block;
      }
      .post-list a:hover .post-title {
        color: var(--accent);
      }
      .post-title {
        font-size: 1rem;
        font-weight: 500;
        margin-bottom: 0.25rem;
      }
      .post-meta {
        font-size: 0.8rem;
        color: var(--muted);
      }
      .post-summary {
        font-size: 0.9rem;
        color: var(--muted);
        margin-top: 0.25rem;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <nav class="back" aria-label="Site">
        <a href="/">← weston.pub</a>
      </nav>
      <h1>Blog</h1>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}`}>
              <div class="post-title">{post.title}</div>
              <div class="post-meta">{post.date}</div>
              <div class="post-summary">{post.summary}</div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </body>
</html>
